{
  "name": "@naskot/<package-name>",
  "version": "0.0.0",
  "description": "<short description>",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/padcmoi/<repo-name>.git"
  },
  "homepage": "https://github.com/padcmoi/<repo-name>",
  "bugs": {
    "url": "https://github.com/padcmoi/<repo-name>/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write .",
    "ci": "npm ci && npm run lint && npm run typecheck && npm test && npm run build",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "keywords": [
    "node",
    "typescript",
    "npm-package"
  ],
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  }
}
